{
  "name": "glucoai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run server\" \"npm run client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install && npm --prefix scripts install",
    "db:generate": "npm --prefix server run db:generate",
    "db:migrate": "npm --prefix server run db:migrate",
    "db:seed": "npm --prefix server run db:seed",
    "db:studio": "npm --prefix server run db:studio",
    "extract:ada": "python scripts/extract_ada_chunks.py",
    "seed:rag": "npm --prefix scripts run seed",
    "eval:rag": "npm --prefix scripts run eval",
    "rag:migrate": "npm --prefix server run rag:migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
